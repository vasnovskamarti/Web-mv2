# Zamezení načítání do rámců cizích domén
Header always append X-Frame-Options SAMEORIGIN
# Ochrana proti XSS
Header set X-XSS-Protection "1; mode=block"

# ── Cache control ─────────────────────────────────────────────
# HTML soubory: vždy čerstvé (žádná cache)
<FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# CSS, JS: cache 1 rok (soubory mají ?v= parametr pro verzování)
<FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Obrázky a fonty: cache 1 měsíc
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|woff|woff2)$">
    Header set Cache-Control "public, max-age=2592000"
</FilesMatch>

ErrorDocument 404 /404.html

# ── Čisté URL bez .html ──────────────────────────────────────
RewriteEngine On

# /index.html → /
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?]
RewriteRule ^ / [R=301,L]

# /xxx.html → /xxx
RewriteCond %{THE_REQUEST} \s/+([^/\.]+)\.html[\s?]
RewriteRule ^ /%1 [R=301,L]

# /xxx → servíruje xxx.html interně
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^/\.]+)/?$ $1.html [L]
