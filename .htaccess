# Zamezení načítání do rámců cizích domén
Header always append X-Frame-Options SAMEORIGIN
# Ochrana proti XSS
Header set X-XSS-Protection "1; mode=block"

ErrorDocument 404 /404.html

# ── Čisté URL bez .html ──────────────────────────────────────
Options -Indexes
RewriteEngine On

# Přesměrování /index nebo /index.html → /
RewriteCond %{THE_REQUEST} ^[A-Z]+\ /index(\.html)?\
RewriteRule ^ / [R=301,L]

# Přesměrování /xxx.html → /xxx (staré záložky / externí odkazy)
RewriteCond %{THE_REQUEST} ^[A-Z]+\ /([^/]+)\.html\
RewriteRule ^([^/]+)\.html$ /$1 [R=301,L]

# Interní obsluha: /sluzby → servíruje sluzby.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^/]+)/?$ $1.html [L]
